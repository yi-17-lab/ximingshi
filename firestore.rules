rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Reusable Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedUser() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. User Entity Rules
    match /users/{userId} {
      // Create user schema validation
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email', 'isPremium', 'createdAt'])
            && data.keys().size() <= 12
            && data.uid is string && data.uid.size() <= 128
            && data.name is string && data.name.size() <= 100
            && data.email is string && data.email.size() <= 150
            && data.isPremium is bool;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(userId) && isValidUser(incoming()) && (incoming().createdAt is string || incoming().createdAt is timestamp);
      allow update: if isOwner(userId) && isVerifiedUser() && isValidUser(incoming())
                       && incoming().uid == existing().uid
                       && incoming().email == existing().email
                       && incoming().createdAt == existing().createdAt;
    }

    // 4. Saved Charts Rules
    match /users/{userId}/charts/{chartId} {
      function isValidChart(data) {
        return data.keys().hasAll(['id', 'userId', 'name', 'gender', 'solarDate', 'lunarDate', 'birthHour', 'createdAt'])
            && data.id is string && data.id.size() <= 128
            && data.userId is string && data.userId.size() <= 128
            && data.name is string && data.name.size() <= 100
            && data.gender is string && data.gender.size() <= 10
            && data.solarDate is string && data.solarDate.size() <= 50
            && data.lunarDate is string && data.lunarDate.size() <= 50
            && data.birthHour is string && data.birthHour.size() <= 20;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(chartId) && isValidChart(incoming()) && (incoming().createdAt is string || incoming().createdAt is timestamp);
      allow update: if isOwner(userId) && isVerifiedUser() && isValidChart(incoming())
                       && incoming().id == existing().id
                       && incoming().userId == existing().userId
                       && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(userId);
    }

    // 5. Forum Posts Rules
    match /forum_posts/{postId} {
      function isValidPost(data) {
        return data.keys().hasAll(['userId', 'userName', 'title', 'content', 'likesCount', 'createdAt'])
            && data.keys().size() <= 8
            && data.userId is string && data.userId.size() <= 128
            && data.userName is string && data.userName.size() <= 100
            && data.title is string && data.title.size() <= 200
            && data.content is string && data.content.size() <= 5000
            && data.likesCount is int;
      }

      allow read: if true;
      allow create: if isVerifiedUser() && isValidId(postId) && isValidPost(incoming())
                       && incoming().userId == request.auth.uid
                       && (incoming().createdAt is timestamp || incoming().createdAt is string)
                       && incoming().likesCount == 0;
      allow update: if isVerifiedUser() && isValidPost(incoming())
                       && incoming().userId == existing().userId
                       && (incoming().createdAt == existing().createdAt)
                       && (
                         // Action 1: Self edit title / content
                         (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content']))
                         ||
                         // Action 2: Anyone likes it
                         (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && (incoming().likesCount == existing().likesCount + 1 || incoming().likesCount == existing().likesCount - 1))
                       );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 6. Consultations Chat Rules
    match /users/{userId}/consultations/{consultationId} {
      function isValidConsultation(data) {
        return data.keys().hasAll(['id', 'userId', 'masterId', 'messages', 'createdAt', 'updatedAt'])
            && data.id is string && data.id.size() <= 128
            && data.userId is string && data.userId.size() <= 128
            && data.masterId is string && data.masterId.size() <= 100
            && data.messages is list;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isVerifiedUser() && isValidId(consultationId) && isValidConsultation(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isVerifiedUser() && isValidConsultation(incoming())
                       && incoming().id == existing().id
                       && incoming().userId == existing().userId
                       && incoming().createdAt == existing().createdAt
                       && incoming().updatedAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
